{
  "description": "Shared conformance cases for the Code evaluation core. Each case's `expr` is a Code AST (the JSON shape authored in instance.schema.json); both the C# and TypeScript interpreters must evaluate it to `expect`. Scalar results only, so the two implementations can be compared directly.",
  "cases": [
    {
      "name": "int literal",
      "text": "5",
      "expr": { "type": "int", "value": 5 },
      "expect": { "kind": "int", "value": 5 }
    },
    {
      "name": "text literal",
      "text": "\"hi\"",
      "expr": { "type": "text", "value": "hi" },
      "expect": { "kind": "text", "value": "hi" }
    },
    {
      "name": "bool literal",
      "text": "true",
      "expr": { "type": "bool", "value": true },
      "expect": { "kind": "bool", "value": true }
    },
    {
      "name": "arithmetic precedence (2*3+4)",
      "text": "2 * 3 + 4",
      "expr": {
        "type": "infixOp", "op": "add",
        "left": { "type": "infixOp", "op": "multiply", "left": { "type": "int", "value": 2 }, "right": { "type": "int", "value": 3 } },
        "right": { "type": "int", "value": 4 }
      },
      "expect": { "kind": "int", "value": 10 }
    },
    {
      "name": "comparison (3 > 1)",
      "text": "3 > 1",
      "expr": { "type": "infixOp", "op": "moreThan", "left": { "type": "int", "value": 3 }, "right": { "type": "int", "value": 1 } },
      "expect": { "kind": "bool", "value": true }
    },
    {
      "name": "integer division truncates (7/2)",
      "text": "7 / 2",
      "expr": { "type": "infixOp", "op": "divide", "left": { "type": "int", "value": 7 }, "right": { "type": "int", "value": 2 } },
      "expect": { "kind": "int", "value": 3 }
    },
    {
      "name": "integer division truncates toward zero (-7/2)",
      "text": "-7 / 2",
      "expr": { "type": "infixOp", "op": "divide", "left": { "type": "int", "value": -7 }, "right": { "type": "int", "value": 2 } },
      "expect": { "kind": "int", "value": -3 }
    },
    {
      "name": "modulo keeps the dividend's sign (-7%3)",
      "text": "-7 % 3",
      "expr": { "type": "infixOp", "op": "modulo", "left": { "type": "int", "value": -7 }, "right": { "type": "int", "value": 3 } },
      "expect": { "kind": "int", "value": -1 }
    },
    {
      "name": "return of a nothing-valued call exits the function",
      "expr": { "type": "call", "params": [],
        "fn": { "type": "fn", "params": [], "body": { "type": "block", "statements": [
          { "type": "return", "value": { "type": "call", "params": [],
            "fn": { "type": "fn", "params": [], "body": { "type": "block", "statements": [] } } } },
          { "type": "return", "value": { "type": "int", "value": 5 } }
        ] } } },
      "expect": { "kind": "nothing", "value": null }
    },
    {
      "name": "text equality",
      "text": "\"a\" == \"a\"",
      "expr": { "type": "infixOp", "op": "equals", "left": { "type": "text", "value": "a" }, "right": { "type": "text", "value": "a" } },
      "expect": { "kind": "bool", "value": true }
    },
    {
      "name": "logical and (false)",
      "text": "1 == 1 && 2 < 1",
      "expr": {
        "type": "infixOp", "op": "and",
        "left": { "type": "infixOp", "op": "equals", "left": { "type": "int", "value": 1 }, "right": { "type": "int", "value": 1 } },
        "right": { "type": "infixOp", "op": "lessThan", "left": { "type": "int", "value": 2 }, "right": { "type": "int", "value": 1 } }
      },
      "expect": { "kind": "bool", "value": false }
    },
    {
      "name": "logical or (true)",
      "text": "1 == 1 || 2 < 1",
      "expr": {
        "type": "infixOp", "op": "or",
        "left": { "type": "infixOp", "op": "equals", "left": { "type": "int", "value": 1 }, "right": { "type": "int", "value": 1 } },
        "right": { "type": "infixOp", "op": "lessThan", "left": { "type": "int", "value": 2 }, "right": { "type": "int", "value": 1 } }
      },
      "expect": { "kind": "bool", "value": true }
    },
    {
      "name": "object prop access",
      "text": "{ n: 7 }.n",
      "expr": {
        "type": "infixOp", "op": "objectProp",
        "left": { "type": "object", "props": [ { "name": "n", "value": { "type": "int", "value": 7 } } ] },
        "right": { "type": "symbol", "name": "n" }
      },
      "expect": { "kind": "int", "value": 7 }
    },
    {
      "name": "dynamic field access sys.field(obj, name)",
      "text": "sys.field({ n: 7 }, \"n\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "field" } },
        "params": [
          { "type": "object", "props": [ { "name": "n", "value": { "type": "int", "value": 7 } } ] },
          { "type": "text", "value": "n" }
        ]
      },
      "expect": { "kind": "int", "value": 7 }
    },
    {
      "name": "sys.humanize a camelCase prop name",
      "text": "sys.humanize(\"companyName\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "humanize" } },
        "params": [ { "type": "text", "value": "companyName" } ]
      },
      "expect": { "kind": "text", "value": "Company name" }
    },
    {
      "name": "sys.clone copies an object's scalar fields",
      "text": "sys.clone({ n: 7 }).n",
      "expr": {
        "type": "infixOp", "op": "objectProp",
        "left": { "type": "call", "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "clone" } },
          "params": [ { "type": "object", "props": [ { "name": "n", "value": { "type": "int", "value": 7 } } ] } ] },
        "right": { "type": "symbol", "name": "n" }
      },
      "expect": { "kind": "int", "value": 7 }
    },
    {
      "name": "sys.nest joins a base path and a segment, trimming a trailing slash",
      "text": "sys.nest(\"/\", \"notes\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "nest" } },
        "params": [ { "type": "text", "value": "/" }, { "type": "text", "value": "notes" } ]
      },
      "expect": { "kind": "text", "value": "/notes" }
    },
    {
      "name": "sys.nest appends a (text) segment to a non-root base",
      "text": "sys.nest(\"/notes\", \"3\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "nest" } },
        "params": [ { "type": "text", "value": "/notes" }, { "type": "text", "value": "3" } ]
      },
      "expect": { "kind": "text", "value": "/notes/3" }
    },
    {
      "name": "sys.nest appends an INT segment to a non-root base (stringifies it)",
      "text": "sys.nest(\"/notes\", 3)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "nest" } },
        "params": [ { "type": "text", "value": "/notes" }, { "type": "int", "value": 3 } ]
      },
      "expect": { "kind": "text", "value": "/notes/3" }
    },
    {
      "name": "sys.nest joins a (text) dictionary key — the same primitive a dict route reuses",
      "text": "sys.nest(\"/settings\", \"theme\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "nest" } },
        "params": [ { "type": "text", "value": "/settings" }, { "type": "text", "value": "theme" } ]
      },
      "expect": { "kind": "text", "value": "/settings/theme" }
    },
    {
      "name": "sys.segment index 0 of a rooted path is the empty leading segment",
      "text": "sys.segment(\"/instances/5\", 0)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "/instances/5" }, { "type": "int", "value": 0 } ]
      },
      "expect": { "kind": "text", "value": "" }
    },
    {
      "name": "sys.segment index 1 of a rooted path",
      "text": "sys.segment(\"/instances/5\", 1)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "/instances/5" }, { "type": "int", "value": 1 } ]
      },
      "expect": { "kind": "text", "value": "instances" }
    },
    {
      "name": "sys.segment index 2 of a rooted path (the route key)",
      "text": "sys.segment(\"/instances/5\", 2)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "/instances/5" }, { "type": "int", "value": 2 } ]
      },
      "expect": { "kind": "text", "value": "5" }
    },
    {
      "name": "sys.segment out of range is empty",
      "text": "sys.segment(\"/instances/5\", 9)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "/instances/5" }, { "type": "int", "value": 9 } ]
      },
      "expect": { "kind": "text", "value": "" }
    },
    {
      "name": "sys.segment of the bare root, index 1, is empty",
      "text": "sys.segment(\"/\", 1)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "/" }, { "type": "int", "value": 1 } ]
      },
      "expect": { "kind": "text", "value": "" }
    },
    {
      "name": "sys.segment of the empty path, index 0, is empty",
      "text": "sys.segment(\"\", 0)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
        "params": [ { "type": "text", "value": "" }, { "type": "int", "value": 0 } ]
      },
      "expect": { "kind": "text", "value": "" }
    },
    {
      "name": "sys.toInt parses a plain number",
      "text": "sys.toInt(\"5\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [ { "type": "text", "value": "5" } ]
      },
      "expect": { "kind": "int", "value": 5 }
    },
    {
      "name": "sys.toInt drops leading zeros (\"007\" -> 7)",
      "text": "sys.toInt(\"007\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [ { "type": "text", "value": "007" } ]
      },
      "expect": { "kind": "int", "value": 7 }
    },
    {
      "name": "sys.toInt of a non-numeric text is 0",
      "text": "sys.toInt(\"x\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [ { "type": "text", "value": "x" } ]
      },
      "expect": { "kind": "int", "value": 0 }
    },
    {
      "name": "sys.toInt of the empty text is 0",
      "text": "sys.toInt(\"\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [ { "type": "text", "value": "" } ]
      },
      "expect": { "kind": "int", "value": 0 }
    },
    {
      "name": "sys.toInt parses a leading minus sign (\"-3\" -> -3)",
      "text": "sys.toInt(\"-3\")",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [ { "type": "text", "value": "-3" } ]
      },
      "expect": { "kind": "int", "value": -3 }
    },
    {
      "name": "sys.toInt(sys.segment(...)) — the routing expression: read a route int from a path",
      "text": "sys.toInt(sys.segment(\"/instances/5\", 2))",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "toInt" } },
        "params": [
          { "type": "call",
            "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "segment" } },
            "params": [ { "type": "text", "value": "/instances/5" }, { "type": "int", "value": 2 } ] }
        ]
      },
      "expect": { "kind": "int", "value": 5 }
    },
    {
      "name": "sys.id reads an object's intrinsic id (a fresh object literal mints -1 identically on both twins)",
      "text": "sys.id({ n: 7 })",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "sys" }, "right": { "type": "symbol", "name": "id" } },
        "params": [ { "type": "object", "props": [ { "name": "n", "value": { "type": "int", "value": 7 } } ] } ]
      },
      "expect": { "kind": "int", "value": -1 }
    },
    {
      "name": "object-field assignment (obj.x = 9) sets the field",
      "expr": {
        "type": "call",
        "fn": { "type": "fn", "params": [ { "name": "o" } ], "body": { "type": "block", "statements": [
          { "type": "assign",
            "target": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "o" }, "right": { "type": "symbol", "name": "x" } },
            "value": { "type": "int", "value": 9 } },
          { "type": "return", "value": { "type": "infixOp", "op": "objectProp", "left": { "type": "symbol", "name": "o" }, "right": { "type": "symbol", "name": "x" } } }
        ] } },
        "params": [ { "type": "object", "props": [ { "name": "x", "value": { "type": "int", "value": 1 } } ] } ]
      },
      "expect": { "kind": "int", "value": 9 }
    },
    {
      "name": "immediately-invoked function (n => n + 1)(41)",
      "text": "(n => n + 1)(41)",
      "expr": {
        "type": "call",
        "fn": {
          "type": "fn",
          "params": [ { "name": "n" } ],
          "body": { "type": "block", "statements": [
            { "type": "return", "value": { "type": "infixOp", "op": "add", "left": { "type": "symbol", "name": "n" }, "right": { "type": "int", "value": 1 } } }
          ] }
        },
        "params": [ { "type": "int", "value": 41 } ]
      },
      "expect": { "kind": "int", "value": 42 }
    },
    {
      "name": "where filters a list (preserving order)",
      "text": "[1, 3, 2].where(x => x > 1)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp",
          "left": { "type": "array", "items": [ { "type": "int", "value": 1 }, { "type": "int", "value": 3 }, { "type": "int", "value": 2 } ] },
          "right": { "type": "symbol", "name": "where" } },
        "params": [ { "type": "fn", "params": [ { "name": "x" } ],
          "body": { "type": "block", "statements": [ { "type": "return", "value":
            { "type": "infixOp", "op": "moreThan", "left": { "type": "symbol", "name": "x" }, "right": { "type": "int", "value": 1 } } } ] } } ]
      },
      "expect": { "kind": "intList", "value": [ 3, 2 ] }
    },
    {
      "name": "where then orderBy chained over a list",
      "text": "[1, 3, 2].where(x => x > 1).orderBy(x => x)",
      "expr": {
        "type": "call",
        "fn": { "type": "infixOp", "op": "objectProp",
          "left": { "type": "call",
            "fn": { "type": "infixOp", "op": "objectProp",
              "left": { "type": "array", "items": [ { "type": "int", "value": 1 }, { "type": "int", "value": 3 }, { "type": "int", "value": 2 } ] },
              "right": { "type": "symbol", "name": "where" } },
            "params": [ { "type": "fn", "params": [ { "name": "x" } ],
              "body": { "type": "block", "statements": [ { "type": "return", "value":
                { "type": "infixOp", "op": "moreThan", "left": { "type": "symbol", "name": "x" }, "right": { "type": "int", "value": 1 } } } ] } } ] },
          "right": { "type": "symbol", "name": "orderBy" } },
        "params": [ { "type": "fn", "params": [ { "name": "x" } ],
          "body": { "type": "block", "statements": [ { "type": "return", "value": { "type": "symbol", "name": "x" } } ] } } ]
      },
      "expect": { "kind": "intList", "value": [ 2, 3 ] }
    },
    {
      "name": "where over the SAME collection with a predicate closing over an outer var disambiguates per value (memo-key closure)",
      "comment": "pick(x) = nums.where(n => n == x) called for x=10 then RETURNING x=20. The lambda AST node — and the collection nums (one id, captured) — are identical across both calls, so keying the where memo on (collection id, lambda id) alone returns pick(10)'s [10] for pick(20). Folding the captured x into the key makes them distinct; the result must be [20], not [10].",
      "expr": {
        "type": "call", "params": [],
        "fn": { "type": "fn", "params": [], "body": { "type": "block", "statements": [
          { "type": "varDec", "name": "nums", "value": { "type": "array", "items": [
            { "type": "int", "value": 10 }, { "type": "int", "value": 20 }, { "type": "int", "value": 30 } ] } },
          { "type": "fn", "name": "pick", "params": [ { "name": "x" } ], "body": { "type": "block", "statements": [
            { "type": "return", "value": {
              "type": "call",
              "fn": { "type": "infixOp", "op": "objectProp",
                "left": { "type": "symbol", "name": "nums" }, "right": { "type": "symbol", "name": "where" } },
              "params": [ { "type": "fn", "params": [ { "name": "n" } ], "body": { "type": "block", "statements": [
                { "type": "return", "value": { "type": "infixOp", "op": "equals",
                  "left": { "type": "symbol", "name": "n" }, "right": { "type": "symbol", "name": "x" } } } ] } } ] } } ] } },
          { "type": "varDec", "name": "a", "value": {
            "type": "call", "fn": { "type": "symbol", "name": "pick" }, "params": [ { "type": "int", "value": 10 } ] } },
          { "type": "return", "value": {
            "type": "call", "fn": { "type": "symbol", "name": "pick" }, "params": [ { "type": "int", "value": 20 } ] } }
        ] } },
        "params": []
      },
      "expect": { "kind": "intList", "value": [ 20 ] }
    },
    {
      "name": "orderBy over the SAME collection with a selector closing over an outer var disambiguates per value (memo-key closure)",
      "comment": "srt(sign) = nums.orderBy(n => n * sign) called for sign=1 (ascending) then RETURNING sign=-1 (descending). Same lambda node + same captured collection across both calls, so a (collection id, lambda id) key returns srt(1)'s ascending order for srt(-1). Folding the captured sign into the key disambiguates; the result must be the descending [3, 2, 1].",
      "expr": {
        "type": "call", "params": [],
        "fn": { "type": "fn", "params": [], "body": { "type": "block", "statements": [
          { "type": "varDec", "name": "nums", "value": { "type": "array", "items": [
            { "type": "int", "value": 1 }, { "type": "int", "value": 2 }, { "type": "int", "value": 3 } ] } },
          { "type": "fn", "name": "srt", "params": [ { "name": "sign" } ], "body": { "type": "block", "statements": [
            { "type": "return", "value": {
              "type": "call",
              "fn": { "type": "infixOp", "op": "objectProp",
                "left": { "type": "symbol", "name": "nums" }, "right": { "type": "symbol", "name": "orderBy" } },
              "params": [ { "type": "fn", "params": [ { "name": "n" } ], "body": { "type": "block", "statements": [
                { "type": "return", "value": { "type": "infixOp", "op": "multiply",
                  "left": { "type": "symbol", "name": "n" }, "right": { "type": "symbol", "name": "sign" } } } ] } } ] } } ] } },
          { "type": "varDec", "name": "a", "value": {
            "type": "call", "fn": { "type": "symbol", "name": "srt" }, "params": [ { "type": "int", "value": 1 } ] } },
          { "type": "return", "value": {
            "type": "call", "fn": { "type": "symbol", "name": "srt" }, "params": [ { "type": "int", "value": -1 } ] } }
        ] } },
        "params": []
      },
      "expect": { "kind": "intList", "value": [ 3, 2, 1 ] }
    },
    {
      "name": "a tag-invoked component is recognized by name and binds its attribute to the param",
      "comment": "<c d={42}> is a tag-invoked component: the name `c` resolves to a function, so it is invoked (not rendered as an HTML element), and the `d` attribute binds to the `d` param BY NAME — c records it in `seen` and the probe reads 42. Both twins recognize and bind identically. (Run-once-ACROSS-re-renders is a client-cache behavior — C#'s Memoize is write-only, the server renders once — so it is proven by the SelfHostedUi Gherkin scenario, not here.)",
      "setup": [
        { "type": "varDec", "name": "seen", "value": { "type": "int", "value": 0 } },
